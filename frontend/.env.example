# Heccker-OS Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local dev:
#   cp .env.example .env.local
#
# On Vercel: Project Settings → Environment Variables → add each key below.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend URL ──────────────────────────────────────────────────────────────
# Local dev:  http://localhost:8000
# Production: https://heccker-api.onrender.com  (or your Render URL)
VITE_API_URL=http://localhost:8000

# ── Google OAuth (for Sign-In with Google) ────────────────────────────────────
# How to get this:
#   1. Go to https://console.cloud.google.com/
#   2. Create a project → APIs & Services → Credentials
#   3. Create an OAuth 2.0 Client ID (Web application)
#   4. Add Authorised JavaScript origins:
#        http://localhost:5173        (local dev)
#        https://your-vercel-app.vercel.app  (production)
#   5. Paste the Client ID below
VITE_GOOGLE_CLIENT_ID=693890987845-ujug2r2tq1n38a7p4h57m2ir46uie3v2.apps.googleusercontent.com
