# Heccker-OS Backend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env for local dev:
#   cp .env.example .env
#
# On Render: Dashboard → Environment → add each key below.
# ─────────────────────────────────────────────────────────────────────────────

# ── Gemini API Key (REQUIRED) ─────────────────────────────────────────────────
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Google Cloud Project (optional — for Vertex AI deployment) ─────────────────
# Required only if deploying to Vertex AI Agent Engine
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global

# ── Cloud ID / Email Integration ─────────────────────────────────────────────
CLOUD_ID_EMAIL=your-email@gmail.com
CLOUD_ID_APP_PASSWORD=your-google-app-password

# ── MCP Client Tokens ────────────────────────────────────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=your-github-pat
DISCORD_BOT_TOKEN=your-discord-bot-token
